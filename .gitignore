# Secrets and environment files
**/.env
**/.env.*
!**/.env.example
!**/.env.sample

# Local credentials and keys
**/*.key
**/*.pem
**/*.p12
**/*.pfx
**/*.jks
**/*.keystore
**/key.properties
**/local.properties

# Flutter / Dart / Pub artifacts
**/.dart_tool/
**/.flutter-plugins-dependencies
**/.pub/
**/.pub-cache/
**/build/
**/coverage/

# Node / backend artifacts
**/node_modules/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS and editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Generated or user-local files
**/*.tmp
**/*.temp
**/*.bak
**/*.orig

# Mobile platform local config
**/android/local.properties
**/android/.gradle/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/ios/Flutter/.last_build_id
**/ios/Pods/
**/macos/Flutter/ephemeral/
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/
